# =============================================================================
# root/.env.example — LinkBay CMS
# =============================================================================
#
# Copia questo file in .env e compila i valori.
# Non committare mai .env con valori reali.
#
# =============================================================================


# -------------------------------------------------------------------------------
# APP - Laravel
# -------------------------------------------------------------------------------
APP_NAME=LinkBay
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://api.localhost

CENTRAL_DOMAIN=linkbay-cms.com


# -------------------------------------------------------------------------------
# PostgreSQL - DB centrale + tenant schemas (schema-per-tenant via stancl/tenancy)
# -------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=linkbay_central
POSTGRES_HOST=db
POSTGRES_PORT=5432

DB_CONNECTION=central
DB_HOST=db
DB_PORT=5432
DB_DATABASE=linkbay_central
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=prefer


# -------------------------------------------------------------------------------
# Redis - Cache + Queue + Sessioni
# -------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis


# -------------------------------------------------------------------------------
# Laravel Sanctum
# -------------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,linkbay-cms.com


# -------------------------------------------------------------------------------
# Mail - Resend API
# -------------------------------------------------------------------------------
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS=noreply@linkbay-cms.com
MAIL_FROM_NAME="${APP_NAME}"


# -------------------------------------------------------------------------------
# Stripe - Abbonamenti + Connect (revenue split)
# -------------------------------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=   # per OAuth Express onboarding

# Prezzi piani (Stripe Price IDs)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=


# -------------------------------------------------------------------------------
# AI Credits
# -------------------------------------------------------------------------------
AI_CREDITS_DEFAULT_COST_PER_1K_TOKENS=1   # crediti consumati per 1K token


# -------------------------------------------------------------------------------
# AppSumo LTD
# -------------------------------------------------------------------------------
APPSUMO_WEBHOOK_SECRET=   # per validare licenze AppSumo


# -------------------------------------------------------------------------------
# Frontend Next.js
# -------------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://api.localhost


# -------------------------------------------------------------------------------
# NODE-RED - Automazioni visive (ex n8n)
# -------------------------------------------------------------------------------
NODE_RED_CREDENTIAL_SECRET=


# -------------------------------------------------------------------------------
# TensorFlow Serving - ML Inference (ex LiteLLM)
# -------------------------------------------------------------------------------
TF_MODEL_NAME=linkbay_model


# -------------------------------------------------------------------------------
# Feature Flags (per plan limits)
# -------------------------------------------------------------------------------
FEATURE_ADVANCED_ANALYTICS=false
FEATURE_MULTI_WAREHOUSE=false
FEATURE_API_ACCESS=true


# -------------------------------------------------------------------------------
# Filament CMS
# -------------------------------------------------------------------------------
FILAMENT_FILESYSTEM_DISK=public

# Panel URLs (utile per debug)
# Super Admin:  http://linkbay-cms.com/admin
# Tenant Store: http://{subdomain}.linkbay-cms.com/admin
# Agency:       http://{agency-slug}.linkbay-cms.com/dashboard


# -------------------------------------------------------------------------------
# fine
# -------------------------------------------------------------------------------
