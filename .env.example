# =============================================================================
# root/.env.example — LinkBayCMS
# =============================================================================
# Questo file è il template BASE per produzione/staging.
# Per sviluppo locale usa i valori .test nel tuo root .env e l'override:
#   docker compose -f compose.yaml -f compose.override.local.yml up -d
#
# Copia in .env e compila i valori. NON committare mai .env con segreti reali.
# =============================================================================

# ── Ambiente ─────────────────────────────────────────────────────────────────
# Produzione: production | Locale: local (abilita auto-approve agency)
APP_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=saas_user
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=saas_db

# ── Dominio principale ────────────────────────────────────────────────────────
# Usato da:
#   - Traefik router rule nel compose.yaml (*.linkbay-cms.com)
#   - Laravel CENTRAL_DOMAIN (governa panelDomain, RegisterController, Filament)
#   - SESSION_DOMAIN (cookie cross-subdomain)
# In produzione: linkbay-cms.com
# In locale:     linkbay-cms.test (override in compose.override.local.yml)
CENTRAL_DOMAIN=linkbay-cms.com
SESSION_DOMAIN=.linkbay-cms.com

# ── Stripe ────────────────────────────────────────────────────────────────────
# Le chiavi con prefisso APP_STRIPE_* vengono rimappate dal compose.yaml
# ai nomi che Laravel config/services.php si aspetta (STRIPE_KEY, STRIPE_SECRET, ecc.)
APP_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
APP_STRIPE_SECRET_KEY=sk_live_REPLACE_ME
# Per locale test mode: pk_test_... e sk_test_... dal Stripe Dashboard
APP_STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
APP_STRIPE_PRICE_STARTER=price_REPLACE_ME
APP_STRIPE_PRICE_PRO=price_REPLACE_ME
APP_STRIPE_PRICE_BUSINESS=price_REPLACE_ME

# ── Node-RED ──────────────────────────────────────────────────────────────────
NODE_RED_CREDENTIAL_SECRET=REPLACE_ME

# ── Frontend (Next.js SSR) ────────────────────────────────────────────────────
# Usato da Next.js lato server (SSR). I valori NEXT_PUBLIC_* client-side
# vengono baked al build time dal file frontend/.env.local (non da qui).
NEXT_PUBLIC_API_BASE_URL=https://app.linkbay-cms.com

# ── TensorFlow Serving (profilo ml) ──────────────────────────────────────────
TF_MODEL_NAME=linkbay_model

# ── Panels (reference) ───────────────────────────────────────────────────────
# Super Admin:  https://app.linkbay-cms.com/linkbay-admin
# Agency panel: https://{slug}.linkbay-cms.com/dashboard
# Tenant panel: https://{subdomain}.linkbay-cms.com/admin
# Agency reg:   https://app.linkbay-cms.com/agency/register
